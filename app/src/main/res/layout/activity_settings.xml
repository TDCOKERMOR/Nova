<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="?attr/colorSurfaceContainer"
        android:elevation="2dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="\u2190"
            android:textSize="20sp"
            style="@style/Widget.Material3.Button.TextButton"
            android:minWidth="0dp"
            android:paddingHorizontal="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="API 配置"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginStart="8dp" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="保存"
            android:textSize="14sp"
            style="@style/Widget.Material3.Button"
            android:minWidth="0dp"
            android:paddingHorizontal="16dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Chat API -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="对话 API"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="API 地址"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:helperText="对话 API 的基础地址">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etChatApiUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="API Key"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_marginTop="14dp"
                app:helperText="对话模型的密钥"
                app:endIconMode="password_toggle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etChatApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="模型名"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_marginTop="14dp"
                app:helperText="对话使用的模型标识">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etChatModel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="24dp"
                android:background="?attr/colorOutlineVariant" />

            <!-- Vision API -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="图片识别 API"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="图生图时分析图片用的多模态模型，留空则复用对话 API"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="API 地址（可选）"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:helperText="留空复用对话API的地址">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etVisionApiUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="API Key（可选）"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_marginTop="14dp"
                app:helperText="留空复用对话API的Key"
                app:endIconMode="password_toggle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etVisionApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="识别模型名"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_marginTop="14dp"
                app:helperText="需要支持多模态的模型，如 gpt-4o">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etVisionModel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="24dp"
                android:background="?attr/colorOutlineVariant" />

            <!-- Image API -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="图片生成 API"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="留空则复用上方对话 API 的地址和 Key"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="API 完整地址（可选）"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:helperText="留空则自动使用 对话地址/v1/images/generations">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etImageApiUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="API Key（可选）"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_marginTop="14dp"
                app:helperText="留空复用对话API的Key"
                app:endIconMode="password_toggle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etImageApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="图片模型名"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_marginTop="14dp"
                app:helperText="图片生成的模型标识">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etImageModel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 底部留白给作者信息 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:minHeight="40dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="一只一无是处的皮卡丘呀"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:alpha="0.5" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
